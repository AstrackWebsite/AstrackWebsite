# ── Supabase ───────────────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard.

# Safe to expose to the browser (used by the client):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side ONLY. Bypasses RLS — used by the seed script.
# Never commit this and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI features (optional) ─────────────────────────────────────────────
# Enables the AsTrack AI tools (certificate scanning, and more to come).
# Server-side ONLY — never prefix with NEXT_PUBLIC_ and never expose to the
# browser. Leave unset and every AI feature simply hides itself; the rest of
# the app runs normally. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=your-anthropic-api-key
